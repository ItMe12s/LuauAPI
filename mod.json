{
	"geode": "5.7.1",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "imes.luauapi",
	"name": "LuauAPI",
	"version": "v0.1.0-beta.1",
	"developer": "imes",
	"early-load": true,
	"load-priority": "first",
	"description": "Shared Luau runtime API for Geode mods.",
	"tags": [
		"universal",
		"utility",
		"developer"
	],
	"api": {
		"include": [
			"include/**/*.hpp"
		]
	},
	"resources": {
		"files": [
			"src/scripts/**/*.luau"
		]
	},
	"settings": {
		"enable-executor": {
			"name": "Enable Script Executor",
			"description": "Load the built-in ImGui script executor on startup.",
			"type": "bool",
			"default": true
		}
	}
}